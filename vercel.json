{
  "headers": [
    {
      "source": "/(logo|logo-mark)\\.(png|webp)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=604800, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml"
        }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        }
      ]
    }
  ],
  "redirects": [
    { "source": "/tags/Inspiration", "destination": "/tag/inspiration", "permanent": true },
    { "source": "/tags/LifeTruths", "destination": "/tag/lifetruths", "permanent": true },
    { "source": "/tags/thoughtoftheday", "destination": "/tag/thoughtoftheday", "permanent": true },
    { "source": "/tags/:path*", "destination": "/tag/:path*", "permanent": true }
  ],
  "rewrites": [
    { "source": "/__/auth/:path*", "destination": "https://readative-803b0.firebaseapp.com/__/auth/:path*" },
    { "source": "/api/posts/:id/like", "destination": "/api/posts?id=:id&action=like" },
    { "source": "/api/posts/:id/rate", "destination": "/api/posts?id=:id&action=rate" },
    { "source": "/api/posts/:id/comments", "destination": "/api/posts?id=:id&action=comments" },
    { "source": "/api/posts/:id", "destination": "/api/posts?id=:id" },
    { "source": "/knowledge", "destination": "/index.html" },
    { "source": "/knowledge/:path*", "destination": "/index.html" },
    { "source": "/post", "destination": "/index.html" },
    { "source": "/post/:path*", "destination": "/index.html" },
    { "source": "/profile", "destination": "/index.html" },
    { "source": "/profile/:path*", "destination": "/index.html" },
    { "source": "/smarttalk", "destination": "/index.html" },
    { "source": "/explore", "destination": "/index.html" },
    { "source": "/explore/:path*", "destination": "/index.html" },
    { "source": "/category", "destination": "/index.html" },
    { "source": "/category/:path*", "destination": "/index.html" },
    { "source": "/topic", "destination": "/index.html" },
    { "source": "/topic/:path*", "destination": "/index.html" },
    { "source": "/tag", "destination": "/index.html" },
    { "source": "/tag/:path*", "destination": "/index.html" }
  ]
}
